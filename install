#!/bin/bash
# Install ygg — Yggdrasil agent orchestrator
# Usage: curl -fsSL https://raw.githubusercontent.com/ng/yggdrasil/main/install | sh
set -e

REPO="ng/yggdrasil"
PREFIX="${PREFIX:-$HOME/.local/bin}"

OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"

case "$ARCH" in
    x86_64|amd64) ARCH="x86_64" ;;
    arm64|aarch64) ARCH="aarch64" ;;
    *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
esac

case "$OS" in
    linux)  TARGET="${ARCH}-unknown-linux-gnu" ;;
    darwin) TARGET="${ARCH}-apple-darwin" ;;
    *)      echo "Unsupported OS: $OS"; exit 1 ;;
esac

# 5 s `--version` smoke against $PREFIX/ygg. Hard perl timeout so a
# wedged binary can't hang the install. Returns 0 on a clean
# `ygg <version>` line, 1 on anything else (SIGKILL, hang, missing
# perl + non-zero exit).
verify_installed() {
    if command -v perl >/dev/null 2>&1; then
        perl -e '
            eval {
                local $SIG{ALRM} = sub { die "timeout\n" };
                alarm 5;
                my $pid = open(my $fh, "-|", $ARGV[0], "--version") or die $!;
                my $line = <$fh>;
                alarm 0;
                close $fh;
                exit 1 unless defined $line && $line =~ /^ygg /;
            };
            exit 1 if $@;
        ' "$PREFIX/ygg"
    else
        # No perl: no timeout. A truly wedged binary will hang, but
        # most platforms ship perl by default.
        "$PREFIX/ygg" --version >/dev/null 2>&1
    fi
}

# Atomic install + macOS codesign + verify + auto-recover. Mirrors
# `make install`. `cp $src $PREFIX/ygg` directly is what bit
# yggdrasil-175: on macOS, overwriting a path whose previous binary
# is in the Gatekeeper cache silently SIGKILLs the next invocation.
# Always go through a sibling `.next` path → atomic mv → codesign
# --force → 5 s `--version` smoke. If the smoke fails on macOS, do a
# hard codesign reset (--remove-signature then re-sign) and retry
# automatically — the recovery is deterministic and safe (yggdrasil-176).
install_atomic() {
    local src="$1"
    mkdir -p "$PREFIX"
    cp "$src" "$PREFIX/ygg.next"
    chmod +x "$PREFIX/ygg.next"
    mv -f "$PREFIX/ygg.next" "$PREFIX/ygg"
    if [ "$OS" = "darwin" ]; then
        codesign --force -s - "$PREFIX/ygg" >/dev/null 2>&1 || true
    fi

    if verify_installed; then
        return 0
    fi

    # First verify failed. On macOS, try a hard codesign reset before
    # giving up — this is the recovery path `make reinstall` runs and
    # it's deterministic + safe to repeat. Anywhere else, fall through.
    if [ "$OS" = "darwin" ]; then
        echo "verify: --version did not respond within 5s — likely Gatekeeper" >&2
        echo "        cache invalidation from a prior install. Re-signing..." >&2
        codesign --remove-signature "$PREFIX/ygg" >/dev/null 2>&1 || true
        codesign --force -s - "$PREFIX/ygg" >/dev/null 2>&1 || true
        if verify_installed; then
            echo "verify: ok after codesign reset." >&2
            return 0
        fi
    fi

    echo "FAIL: $PREFIX/ygg --version did not return cleanly within 5s," >&2
    echo "      even after a codesign reset on macOS. This is unusual." >&2
    echo "      Diagnostics:" >&2
    echo "        $PREFIX/ygg --version       # see if it errors or hangs" >&2
    echo "        file $PREFIX/ygg            # confirm it's the right arch" >&2
    if [ "$OS" = "darwin" ]; then
        echo "        codesign -dv $PREFIX/ygg     # show signature state" >&2
    fi
    exit 1
}

echo "Installing ygg for ${OS}/${ARCH}..."

# Check for prebuilt binary from GitHub releases
LATEST=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null | grep '"tag_name"' | cut -d'"' -f4 || true)

if [ -n "$LATEST" ]; then
    URL="https://github.com/${REPO}/releases/download/${LATEST}/ygg-${TARGET}"
    echo "Downloading ${LATEST}..."
    curl -fsSL -o /tmp/ygg "$URL"
    install_atomic /tmp/ygg
    rm -f /tmp/ygg
    echo "ygg ${LATEST} installed to ${PREFIX}/ygg"
else
    # No release found — build from source
    echo "No prebuilt binary found. Building from source..."
    if ! command -v cargo &>/dev/null; then
        if [ -f "$HOME/.cargo/env" ]; then
            . "$HOME/.cargo/env"
        fi
    fi

    if ! command -v cargo &>/dev/null; then
        echo "Installing Rust toolchain..."
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
        . "$HOME/.cargo/env"
    fi

    TMPDIR=$(mktemp -d)
    git clone --depth 1 "https://github.com/${REPO}.git" "$TMPDIR/ygg"
    cd "$TMPDIR/ygg"
    cargo build --release
    install_atomic target/release/ygg
    rm -rf "$TMPDIR"
    echo "ygg installed to ${PREFIX}/ygg (built from source)"
fi

# Ensure PREFIX is on PATH
if ! echo "$PATH" | grep -q "$PREFIX"; then
    echo ""
    echo "Add to your shell profile:"
    echo "  export PATH=\"$PREFIX:\$PATH\""
    export PATH="$PREFIX:$PATH"
fi

echo ""
echo "Bootstrapping dependencies..."
echo ""

ygg init
